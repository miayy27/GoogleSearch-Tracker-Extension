{
    "manifest_version": 2,
    "name": "SearchListener",
    "version": "2.0",
    "permissions": [
        "storage",
        "downloads",
        "fileSystem"
    ],
    "browser_action": {
        "default_popup": "options.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "background": {
        "scripts": [
            "background.js"
        ],
        "persistent": false
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon.png"
      }
      
}
